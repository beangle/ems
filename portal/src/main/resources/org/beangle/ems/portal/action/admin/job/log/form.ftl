[#ftl]
[@b.head/]
[@b.toolbar title="计划任务执行日志"]bar.addBack();[/@]
  [@b.form action=b.rest.save(cronTaskLog) theme="list"]
    [@b.select name="cronTaskLog.task.id" label="计划任务" value=cronTaskLog.task! items=cronTasks option="id,name" required="true"/]
    [@b.datetime name="cronTaskLog.executeAt" label="执行时间" value=cronTaskLog.executeAt! required="true"/]
    [#assign durationVal = ""]
    [#if cronTaskLog.duration??]
      [#assign durationVal = cronTaskLog.duration.toMillis?c]
    [/#if]
    [@b.textfield name="durationMillis" label="耗时(毫秒)" value=durationVal maxlength="20" comment="执行耗时，单位毫秒"/]
    [@b.select name="cronTaskLog.statusCode" label="状态" value=cronTaskLog.statusCode! items="0:成功,1:失败,2:运行中"/]
    [@b.textfield name="cronTaskLog.resultFilePath" label="结果文件路径" value=(cronTaskLog.resultFilePath)! maxlength="500"/]
    [@b.formfoot]
      [@b.reset/]&nbsp;&nbsp;[@b.submit value="action.submit"/]
    [/@]
  [/@]
[@b.foot/]
